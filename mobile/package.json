{
  "name": "@bairronow/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "caller": {
            "name": "metro",
            "bundler": "metro",
            "platform": "ios"
          }
        }
      ]
    },
    "setupFiles": [
      "<rootDir>/jest-setup.js"
    ],
    "moduleNameMapper": {
      "^@/app/(.*)$": "<rootDir>/app/$1",
      "^@/(.*)$": "<rootDir>/src/$1",
      "\\.png$": "<rootDir>/jest-setup.js",
      "\\.jpg$": "<rootDir>/jest-setup.js"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@microsoft/signalr|@bairronow|zustand|zod))"
    ]
  },
  "dependencies": {
    "@bairronow/shared-api-client": "workspace:*",
    "@bairronow/shared-types": "workspace:*",
    "@bairronow/shared-validators": "workspace:*",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "8.0.7",
    "@react-native-async-storage/async-storage": "2.1.2",
    "axios": "^1.14.0",
    "expo": "~54.0.33",
    "expo-auth-session": "^55.0.13",
    "expo-constants": "~17.0.5",
    "expo-crypto": "^55.0.14",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^55.0.16",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.20",
    "expo-sharing": "^55.0.18",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^55.0.14",
    "react": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.17",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.15",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
