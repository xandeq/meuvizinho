{
  "expo": {
    "name": "Meu Vizinho",
    "slug": "meuvizinho",
    "scheme": "meuvizinho",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#19975d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meuvizinho.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos acessar sua câmera para enviar comprovante de residência",
        "NSPhotoLibraryUsageDescription": "Precisamos acessar suas fotos para enviar comprovante de residência"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/icon.png",
        "backgroundColor": "#19975d"
      },
      "package": "com.meuvizinho.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/brand/icon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-notifications", {
        "icon": "./assets/brand/icon.png",
        "color": "#19975d",
        "sounds": []
      }],
      ["react-native-maps", {
        "androidGoogleMapsApiKey": "YOUR_ANDROID_GOOGLE_MAPS_API_KEY",
        "iosGoogleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
      }]
    ],
    "extra": {
      "apiUrl": "https://api.bairronow.com.br",
      "eas": {
        "projectId": "meuvizinho"
      }
    }
  }
}
