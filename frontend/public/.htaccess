# BairroNow static export — HostGator Apache
# Next.js `output: 'export'` only pre-renders placeholder IDs for dynamic routes.
# Users who share/paste/refresh a URL like /marketplace/123 would get 404 without this.
# This rewrite serves the pre-rendered placeholder shell; the client component
# reads the real ID from window.location via useParams() and fetches via API.

# ─── Cache Control ────────────────────────────────────────────────────────────
# HTML pages: always revalidate so stale HTML never references deleted CSS/JS
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Content-hashed assets: cache forever (filename changes with every build)
<FilesMatch "^.*\.[a-f0-9]{8,}\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Service worker: must never be cached so updates reach users immediately
<FilesMatch "^sw\.js$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Service-Worker-Allowed "/"
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # More-specific routes first (edit sub-route before generic detail)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^marketplace/[0-9]+/edit/?$ /marketplace/0/edit/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^groups/[0-9]+/events/?$ /groups/placeholder/events/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/areas-comuns/[0-9]+/?$ /condominios/placeholder/areas-comuns/placeholder/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/areas-comuns/?$ /condominios/placeholder/areas-comuns/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/gerenciar/areas-comuns/?$ /condominios/placeholder/gerenciar/areas-comuns/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/gerenciar/moradores/?$ /condominios/placeholder/gerenciar/moradores/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/gerenciar/reservas/?$ /condominios/placeholder/gerenciar/reservas/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/minhas-reservas/?$ /condominios/placeholder/minhas-reservas/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/vincular/?$ /condominios/placeholder/vincular/index.html [L]

  # Generic dynamic-segment fallbacks
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^marketplace/[0-9]+/?$ /marketplace/0/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^chat/[0-9]+/?$ /chat/0/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^groups/[0-9]+/?$ /groups/placeholder/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^condominios/[0-9]+/?$ /condominios/placeholder/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^m/[^/]+/?$ /m/preview/index.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^p/[^/]+/?$ /p/preview/index.html [L]
</IfModule>
